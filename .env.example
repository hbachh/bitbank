# AI Young Guru - Environment Variables Configuration

# ===========================================
# DATABASE CONFIGURATION (TiDB Serverless)
# ===========================================
# Use TIDB_URI for the serverless HTTP connection string
TIDB_URI=mysql://your_user.root:your_password@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/aiyoungguru
# TIDB_CA_PATH is no longer required for the serverless HTTP driver
# TIDB_CA_PATH=./isrgrootx1.pem

# ===========================================
# GOOGLE AI STUDIO API (Gemini / Gemma)
# ===========================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_ai_studio_api_key_here
GEMMA_API_KEY=your_google_ai_studio_api_key_here

# ===========================================
# EMAIL CONFIGURATION (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@aiyoungguru.com

# ===========================================
# JWT CONFIGURATION
# ===========================================
JWT_SECRET=your_jwt_secret_key_here

# ===========================================
# APPLICATION SETTINGS
# ===========================================
PORT=8000
